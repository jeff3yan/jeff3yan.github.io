---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Remoji Terms of Service">
  <main class="mx-auto max-w-3xl px-6 pt-28 pb-20 text-slate-200">
    <h1 class="font-display text-3xl font-semibold text-white">Terms of Service</h1>
    <p class="mt-2 text-sm text-slate-400">Last updated: March 14, 2026</p>

    <div class="mt-8 space-y-4 text-sm text-slate-300 leading-relaxed">
      <p>
        By installing or using Remoji, you agree to these terms.
      </p>

      <p>
        <strong class="text-white">Use of the service:</strong> Remoji is provided on a best-effort basis.
        You are responsible for ensuring your use complies with your organization’s policies.
      </p>

      <p>
        <strong class="text-white">Availability:</strong> We aim to keep the service available, but we do not guarantee
        uninterrupted operation.
      </p>

      <p>
        <strong class="text-white">Data:</strong> Your use of Remoji is governed by our Privacy Policy.
      </p>

      <p>
        <strong class="text-white">Contact:</strong> Questions or concerns? Email
        <a href="mailto:hello@remoji.ai" class="text-emerald-200 hover:text-white transition-colors">hello@remoji.ai</a>.
      </p>
    </div>
  </main>
</Layout>
