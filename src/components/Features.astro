---
// Icons: GIFs used where they map naturally to the concept.
// 🎯 kept static — no GIF in the set conveys "finding the right thing"
// without feeling off-brand. The others map well at emoji size.
const features = [
  {
    gif: null,
    icon: '🧠',
    title: 'Search by meaning, not names',
    description: 'Describe the vibe, use a similar emoji, or type the feeling. Remoji understands context and returns the closest matches.',
  },
  {
    gif: 'extreme-teamwork.gif',
    icon: null,
    title: 'Built for emoji-heavy teams',
    description: 'The larger your custom library, the more valuable Remoji gets. It indexes what you already have.',
  },
  {
    gif: null,
    icon: '🔄',
    title: 'Always up to date',
    description: 'New emojis are picked up automatically, so the results stay fresh without anyone managing it.',
  },
  {
    gif: null,
    icon: '🧾',
    title: 'Admin-friendly billing',
    description: 'Self-serve upgrades, downgrades, and cancellations live in the Slack App Home tab via a secure portal.',
  },
];
---

<section id="features" class="py-24 px-6 border-t border-white/10">
  <div class="mx-auto max-w-6xl">
    <div class="text-center mb-16 fade-up">
      <h2 class="font-display text-3xl font-semibold text-white sm:text-4xl">Why teams use Remoji</h2>
      <p class="mt-4 text-slate-400">Designed for fast-moving Slack teams and the buyers who support them.</p>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      {features.map((f, i) => (
        <div
          class="fade-up rounded-2xl border border-white/10 bg-white/[0.03] p-6 hover:border-emerald-200/30 hover:bg-white/[0.06] transition-colors"
          style={`transition-delay: ${i * 80}ms`}
        >
          <div class="mb-4">
            {f.gif
              ? <img src={`/emojis/${f.gif}`} alt="" class="size-8 object-contain" loading="lazy" />
              : <span class="text-3xl">{f.icon}</span>
            }
          </div>
          <h3 class="text-base font-semibold text-white mb-2">{f.title}</h3>
          <p class="text-sm text-slate-400 leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
