---
// Icons: GIFs used where they map naturally to the concept.
// 🎯 kept static — no GIF in the set conveys "finding the right thing"
// without feeling off-brand. The others map well at emoji size.
const features = [
  {
    gif: null,
    icon: '🎯',
    title: "Finds what you're thinking of",
    description: "Describe the vibe, use a similar emoji, or just type the feeling — Remoji understands context, not just names.",
  },
  {
    gif: 'extreme-teamwork.gif',
    icon: null,
    title: 'Built around your workspace',
    description: "Works with the custom emojis your team already has. The bigger your collection, the better the recommendations.",
  },
  {
    gif: 'bananadance.gif',
    icon: null,
    title: 'Always fresh results',
    description: "Results are ranked for variety — you see a diverse spread, not the same few emojis every time.",
  },
  {
    gif: 'typingcat.gif',
    icon: null,
    title: 'Instant for everyone',
    description: "Once anyone on your team searches, the whole team gets instant answers. No waiting around.",
  },
];
---

<section class="py-24 px-6 border-t border-white/5">
  <div class="mx-auto max-w-5xl">
    <div class="text-center mb-16 fade-up">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Why teams use Remoji</h2>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      {features.map((f, i) => (
        <div
          class="fade-up rounded-2xl border border-white/5 bg-white/[0.03] p-6 hover:border-violet-500/20 hover:bg-white/[0.05] transition-colors"
          style={`transition-delay: ${i * 80}ms`}
        >
          <div class="mb-4">
            {f.gif
              ? <img src={`/emojis/${f.gif}`} alt="" class="size-8 object-contain" />
              : <span class="text-3xl">{f.icon}</span>
            }
          </div>
          <h3 class="text-base font-semibold text-white mb-2">{f.title}</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
