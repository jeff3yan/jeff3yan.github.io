---
const tiers = [
  {
    name: 'Free',
    price: '$0',
    period: 'forever',
    emojiLimit: 'Up to 500 custom emojis',
    bestFor: 'Small teams trying Remoji',
    note: 'Includes emoji search, recommendations, and automatic updates.',
    highlighted: false,
  },
  {
    name: 'Pro',
    price: '$12',
    period: 'per month',
    emojiLimit: 'Up to 5,000 custom emojis',
    bestFor: 'Mid-size companies with active emoji culture',
    note: 'Priority support and faster turnaround for new features.',
    highlighted: true,
  },
  {
    name: 'Business',
    price: '$29',
    period: 'per month',
    emojiLimit: 'Unlimited custom emojis',
    bestFor: 'Large orgs with security and SLA needs',
    note: 'Best-effort email support, priority for critical issues, and early-access roadmap input.',
    highlighted: false,
  },
];
---

<section id="pricing" class="py-24 px-6 border-t border-white/10">
  <div class="mx-auto max-w-6xl">
    <div class="text-center mb-14 fade-up">
      <h2 class="font-display text-3xl font-semibold text-white sm:text-4xl">Plans that scale with your emoji library</h2>
      <p class="mt-4 text-slate-400">
        Pricing is based on the size of your custom emoji collection, not per seat.
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
      {tiers.map((tier, i) => (
        <div
          class={`fade-up rounded-2xl border p-6 flex flex-col gap-4 ${tier.highlighted ? 'border-emerald-400/40 bg-emerald-400/[0.06] ring-1 ring-emerald-400/20' : 'border-white/10 bg-white/[0.03]'}`}
          style={`transition-delay: ${i * 90}ms`}
        >
          <div class="flex items-center justify-between">
            <h3 class="font-display text-xl font-semibold text-white">{tier.name}</h3>
            {tier.highlighted && <span class="text-xs uppercase tracking-wide text-emerald-300 font-semibold">Most popular</span>}
          </div>
          <div class="flex items-end gap-1">
            <span class="font-display text-4xl font-bold text-white">{tier.price}</span>
            <span class="text-sm text-slate-400 mb-1">/ {tier.period}</span>
          </div>
          <div class="text-sm text-slate-300 font-semibold">{tier.emojiLimit}</div>
          <p class="text-sm text-slate-400">{tier.bestFor}</p>
          <p class="text-sm text-slate-400">{tier.note}</p>
        </div>
      ))}
    </div>

    <p class="mt-10 text-center text-sm text-slate-400 fade-up">
      Pricing is per workspace, not per seat. All plans include a 14-day free trial.
    </p>
  </div>
</section>
