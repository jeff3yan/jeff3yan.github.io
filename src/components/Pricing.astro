---
const tiers = [
  {
    name: 'Free',
    price: '$0',
    period: 'forever',
    emojiLimit: 'Up to 500 custom emojis',
    bestFor: 'Small teams trying Remoji',
    features: [
      'Emoji search & recommendations',
      'Automatic library updates',
      'All team members can use /remoji',
      'Self-serve billing portal',
    ],
    highlighted: false,
    ctaLabel: 'Add to Slack — free',
    ctaHref: 'https://api.getremoji.com/slack/install',
  },
  {
    name: 'Pro',
    price: '$12',
    period: 'per month',
    emojiLimit: 'Up to 5,000 custom emojis',
    bestFor: 'Mid-size companies with active emoji culture',
    features: [
      'Everything in Free',
      'Priority support',
      'Faster turnaround on new features',
      '14-day free trial',
    ],
    highlighted: true,
    ctaLabel: 'Get started',
    ctaHref: 'https://api.getremoji.com/slack/install',
  },
  {
    name: 'Business',
    price: '$29',
    period: 'per month',
    emojiLimit: 'Unlimited custom emojis',
    bestFor: 'Large orgs with security and SLA needs',
    features: [
      'Everything in Pro',
      'Priority response for critical issues',
      'Early-access roadmap input',
      'Workspace-isolated data storage',
    ],
    highlighted: false,
    ctaLabel: 'Get started',
    ctaHref: 'https://api.getremoji.com/slack/install',
  },
];
---

<section id="pricing" class="py-24 px-6 border-t border-white/10">
  <div class="mx-auto max-w-6xl">
    <div class="text-center mb-14 fade-up">
      <h2 class="font-display text-3xl font-semibold text-white sm:text-4xl">Plans that scale with your emoji library</h2>
      <p class="mt-4 text-slate-400">
        Pricing is based on the size of your custom emoji collection, not per seat.
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
      {tiers.map((tier, i) => (
        <div
          class={`fade-up rounded-2xl border p-6 flex flex-col gap-4 ${tier.highlighted ? 'border-emerald-400/40 bg-emerald-400/[0.06] ring-1 ring-emerald-400/20' : 'border-white/10 bg-white/[0.03]'}`}
          style={`transition-delay: ${i * 90}ms`}
        >
          <div class="flex items-center justify-between">
            <h3 class="font-display text-xl font-semibold text-white">{tier.name}</h3>
            {tier.highlighted && <span class="text-xs uppercase tracking-wide text-emerald-300 font-semibold">Most popular</span>}
          </div>
          <div class="flex items-end gap-1">
            <span class="font-display text-4xl font-bold text-white">{tier.price}</span>
            <span class="text-sm text-slate-400 mb-1">/ {tier.period}</span>
          </div>
          <div class="text-sm text-slate-300 font-semibold">{tier.emojiLimit}</div>
          <p class="text-sm text-slate-400">{tier.bestFor}</p>
          <ul class="space-y-1.5 pt-1">
            {tier.features.map(f => (
              <li class="flex items-start gap-2 text-sm text-slate-400">
                <svg class="size-4 flex-shrink-0 mt-0.5 text-emerald-400" viewBox="0 0 16 16" fill="none">
                  <path d="M3 8l3.5 3.5L13 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <div class="mt-auto pt-2">
            <a
              href={tier.ctaHref}
              class={`inline-flex items-center gap-2 rounded-full px-5 py-2 text-sm font-semibold transition-colors ${tier.highlighted ? 'bg-white text-slate-900 hover:bg-slate-100' : 'bg-white/10 text-white hover:bg-white/20 border border-white/10'}`}
            >
              {tier.highlighted && (
                <img src="https://a.slack-edge.com/80588/marketing/img/icons/icon_slack_hash_colored.png" alt="" class="size-4" />
              )}
              {tier.ctaLabel}
            </a>
          </div>
        </div>
      ))}
    </div>

    <p class="mt-10 text-center text-sm text-slate-400 fade-up">
      Pricing is per workspace, not per seat. Paid plans include a 14-day free trial.
    </p>
  </div>
</section>
