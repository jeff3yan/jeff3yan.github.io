---
const steps = [
  {
    number: '1',
    title: 'Add to Slack',
    description: 'Click the button, authorize Remoji in your workspace. Takes about 30 seconds.',
  },
  {
    number: '2',
    title: 'Remoji learns your emojis',
    description: 'In the background, Remoji analyzes every custom emoji using AI — what it looks like, its mood, style, and meaning.',
  },
  {
    number: '3',
    title: 'Find any emoji, instantly',
    description: 'Type /remoji :any-emoji: in any channel. Your whole team gets ranked recommendations from your own collection.',
  },
];
---

<section class="py-24 px-6">
  <div class="mx-auto max-w-5xl">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Up and running in minutes</h2>
      <p class="mt-4 text-zinc-400">No configuration. No maintenance. Just install and go.</p>
    </div>

    <div class="grid sm:grid-cols-3 gap-8">
      {steps.map((step) => (
        <div class="relative flex flex-col">
          <div class="mb-5 flex items-center gap-4">
            <div class="flex size-10 items-center justify-center rounded-full border border-violet-500/30 bg-violet-500/10 text-sm font-bold text-violet-300 flex-shrink-0">
              {step.number}
            </div>
            <!-- connector line (hidden on last item) -->
            <div class="hidden sm:block h-px flex-1 bg-gradient-to-r from-violet-500/20 to-transparent last-of-type:hidden"></div>
          </div>
          <h3 class="text-base font-semibold text-white mb-2">{step.title}</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <a
        href="https://slack.com/oauth/v2/authorize"
        class="inline-flex items-center gap-3 rounded-xl bg-[#4A154B] px-6 py-3 text-base font-semibold text-white shadow-lg hover:bg-[#3d1140] transition-colors"
      >
        <img src="https://a.slack-edge.com/80588/marketing/img/icons/icon_slack_hash_colored.png" alt="" class="size-5" />
        Add to Slack — it's free
      </a>
    </div>
  </div>
</section>
