---
const steps = [
  {
    number: '1',
    title: 'Add to Slack',
    description: 'Click the button and authorize Remoji in your workspace.',
  },
  {
    number: '2',
    title: 'Remoji learns your emojis',
    description: 'In the background, Remoji reads every custom emoji and builds an understanding of what each one looks like, its mood, and meaning.',
  },
  {
    number: '3',
    title: 'Find any emoji, instantly',
    description: 'Type /remoji :any-emoji: in any channel. Your whole team gets recommendations drawn from your own collection.',
  },
];
---

<section class="py-24 px-6 border-t border-white/5">
  <div class="mx-auto max-w-5xl">
    <div class="text-center mb-16 fade-up">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Install once, works for your whole team</h2>
      <p class="mt-4 text-zinc-400">No configuration. No maintenance. Just install and go.</p>
    </div>

    <div class="grid sm:grid-cols-3 gap-8">
      {steps.map((step, i) => (
        <div
          class="fade-up relative flex flex-col"
          style={`transition-delay: ${i * 100}ms`}
        >
          <div class="mb-5 flex items-center gap-4">
            <div class="flex size-10 items-center justify-center rounded-full border border-violet-500/30 bg-violet-500/10 text-sm font-bold text-violet-300 flex-shrink-0">
              {step.number}
            </div>
            <div class="hidden sm:block h-px flex-1 bg-gradient-to-r from-violet-500/20 to-transparent"></div>
          </div>
          <h3 class="text-base font-semibold text-white mb-2">{step.title}</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
