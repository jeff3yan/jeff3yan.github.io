---
---

<section class="relative pt-32 pb-16 px-6">
  <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_bottom,transparent_60%,rgb(9,9,11)_100%)]"></div>
  <div
    class="pointer-events-none absolute inset-0 opacity-25"
    style="background-image: radial-gradient(ellipse at 50% -10%, rgb(139,92,246) 0%, transparent 55%);"
  ></div>

  <div class="relative mx-auto max-w-3xl text-center">
    <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-violet-500/30 bg-violet-500/10 px-3 py-1 text-xs font-medium text-violet-300">
      ✨ AI-powered emoji discovery for Slack
    </div>

    <h1 class="text-5xl font-bold tracking-tight text-white sm:text-6xl lg:text-7xl">
      The perfect emoji<br />
      <span class="text-violet-400">is already in your workspace</span>
    </h1>

    <p class="mt-6 text-lg leading-8 text-zinc-400 max-w-2xl mx-auto">
      Your team spent time building a library of custom emojis. Remoji makes sure everyone can actually find them — just type <code class="rounded bg-zinc-800 px-1.5 py-0.5 text-sm font-mono text-violet-300">/remoji :any-emoji:</code> and get instant, AI-ranked suggestions from your own collection.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="https://slack.com/oauth/v2/authorize"
        class="inline-flex items-center gap-3 rounded-xl bg-[#4A154B] px-6 py-3 text-base font-semibold text-white shadow-lg hover:bg-[#3d1140] transition-colors"
      >
        <img src="https://a.slack-edge.com/80588/marketing/img/icons/icon_slack_hash_colored.png" alt="" class="size-5" />
        Add to Slack — it's free
      </a>
    </div>

    <p class="mt-4 text-xs text-zinc-600">No credit card required &middot; Works with any Slack workspace</p>
  </div>

  <!-- Product demo mockup -->
  <div class="relative mx-auto mt-16 max-w-2xl">
    <!-- glow behind the card -->
    <div class="pointer-events-none absolute -inset-4 rounded-3xl opacity-30" style="background: radial-gradient(ellipse at 50% 50%, rgb(139,92,246), transparent 70%);"></div>

    <div class="relative rounded-2xl border border-white/10 bg-zinc-900 shadow-2xl overflow-hidden">
      <!-- Fake Slack titlebar -->
      <div class="flex items-center gap-2 px-4 py-3 bg-zinc-950 border-b border-white/5">
        <div class="flex gap-1.5">
          <div class="size-3 rounded-full bg-zinc-700"></div>
          <div class="size-3 rounded-full bg-zinc-700"></div>
          <div class="size-3 rounded-full bg-zinc-700"></div>
        </div>
        <span class="ml-2 text-xs text-zinc-500 font-medium"># general</span>
      </div>

      <!-- User message -->
      <div class="px-5 pt-5 pb-3 flex items-start gap-3">
        <div class="size-9 rounded-lg bg-indigo-600 flex items-center justify-center text-sm font-bold text-white flex-shrink-0 select-none">J</div>
        <div>
          <div class="flex items-baseline gap-2">
            <span class="text-sm font-bold text-white">jeff</span>
            <span class="text-xs text-zinc-500">Today at 3:14 PM</span>
          </div>
          <p class="mt-1 text-sm text-zinc-300 font-mono">/remoji :blob-wave:</p>
        </div>
      </div>

      <!-- Remoji response -->
      <div class="mx-5 mb-5 rounded-xl border border-violet-500/20 bg-violet-500/5 p-4">
        <div class="flex items-start gap-3">
          <div class="size-9 rounded-lg bg-violet-700 flex items-center justify-center text-base flex-shrink-0 select-none">😄</div>
          <div class="min-w-0">
            <div class="flex items-baseline gap-2">
              <span class="text-sm font-bold text-white">Remoji</span>
              <span class="text-xs text-zinc-500 bg-zinc-800 px-1.5 py-0.5 rounded text-[10px]">App</span>
            </div>
            <p class="mt-1 text-sm text-zinc-300">Here are the closest matches to <span class="font-mono text-violet-300">:blob-wave:</span> in your workspace:</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {[
                'blobdance', 'blob-thumbs-up', 'blob-heart',
                'blobhype', 'blob-salute', 'wave-animated',
              ].map((name) => (
                <span class="inline-flex items-center gap-1.5 rounded-lg bg-zinc-800 border border-white/5 px-2.5 py-1.5 text-xs text-zinc-200 font-mono hover:border-violet-500/30 hover:bg-zinc-700 transition-colors cursor-default">
                  :{name}:
                </span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
