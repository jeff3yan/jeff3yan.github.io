<section class="py-24 px-6">
  <div class="mx-auto max-w-3xl text-center">
    <div class="fade-up rounded-3xl border border-emerald-200/20 bg-[radial-gradient(circle_at_top,rgba(94,234,212,0.18),transparent_60%)] px-8 py-16">
      <h2 class="font-display text-3xl font-semibold text-white sm:text-4xl">
        Give your team their emoji superpower
      </h2>
      <p class="mt-4 text-slate-300 max-w-md mx-auto">
        Remoji makes custom emojis discoverable for everyone — beloved by your team, easy to justify to the boss.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="https://api.getremoji.com/slack/install"
          class="inline-flex items-center gap-3 rounded-full bg-white px-6 py-3 text-base font-semibold text-slate-900 shadow-lg hover:bg-slate-100 transition-colors"
        >
          <img src="/slack-icon.png" alt="" class="size-5" />
          Add to Slack
        </a>
        <a
          href="mailto:info@getremoji.com"
          class="inline-flex items-center gap-2 rounded-full border border-emerald-200/40 px-6 py-3 text-base font-semibold text-emerald-100 hover:border-emerald-200/70 hover:text-white transition-colors"
        >
          Contact sales
        </a>
      </div>
      <p class="mt-4 text-xs text-slate-400">No configuration &middot; Works with any Slack workspace</p>
    </div>
  </div>
</section>
