---
// Three rotating emoji result sets — all party/celebration themed
// to match the :partyparrot: input
const emojiSets = [
  [
    { name: 'party_blob',       file: 'party_blob.gif' },
    { name: 'meow_party',       file: 'meow_party.gif' },
    { name: 'bananadance',      file: 'bananadance.gif' },
    { name: 'extreme-teamwork', file: 'extreme-teamwork.gif' },
    { name: 'blob-yes',         file: 'blob-yes.png' },
    { name: 'chefs-kiss',       file: 'chefs-kiss.gif' },
  ],
  [
    { name: 'meow_party',            file: 'meow_party.gif' },
    { name: 'bananadance',           file: 'bananadance.gif' },
    { name: 'party_blob',            file: 'party_blob.gif' },
    { name: 'typingcat',             file: 'typingcat.gif' },
    { name: 'blob_aww',              file: 'blob_aww.png' },
    { name: 'mild-panic-intensifies',file: 'mild-panic-intensifies.gif' },
  ],
  [
    { name: 'bananadance',      file: 'bananadance.gif' },
    { name: 'extreme-teamwork', file: 'extreme-teamwork.gif' },
    { name: 'blob_smiley',      file: 'blob_smiley.png' },
    { name: 'meow_party',       file: 'meow_party.gif' },
    { name: 'blob-no',          file: 'blob-no.png' },
    { name: 'chefs-kiss',       file: 'chefs-kiss.gif' },
  ],
];
---

<div class="relative mx-auto mt-16 max-w-2xl">
  <!-- glow behind the card -->
  <div
    class="pointer-events-none absolute -inset-6 rounded-3xl opacity-20"
    style="background: radial-gradient(ellipse at 50% 50%, rgb(139,92,246), transparent 70%);"
  ></div>

  <!-- Slack window chrome -->
  <div class="relative rounded-2xl overflow-hidden shadow-2xl border border-white/10 flex" style="height: 420px; background: #1a1d21;">

    <!-- Sidebar -->
    <div class="flex-shrink-0 w-52 flex flex-col border-r border-white/5" style="background: #19171d;">
      <!-- Workspace name -->
      <div class="px-4 py-3 flex items-center justify-between border-b border-white/5">
        <span class="text-sm font-bold text-white truncate">Acme Corp</span>
        <svg class="size-4 text-zinc-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z"/></svg>
      </div>
      <!-- Channel list -->
      <div class="flex-1 overflow-hidden py-2 px-2 space-y-0.5 text-sm">
        <div class="px-2 py-0.5 text-xs font-semibold text-zinc-500 uppercase tracking-wide mt-1">Channels</div>
        {['general', 'random', 'design', 'engineering', 'announcements'].map((ch, i) => (
          <div class={`px-2 py-1 rounded flex items-center gap-2 cursor-default ${ch === 'general' ? 'bg-violet-600/30 text-white' : 'text-zinc-400'}`}>
            <span class="text-zinc-500">#</span>
            <span class="truncate">{ch}</span>
            {ch === 'random' && <span class="ml-auto text-xs bg-zinc-600 text-zinc-300 rounded-full px-1.5 py-0.5 leading-none">3</span>}
          </div>
        ))}
      </div>
      <!-- User footer -->
      <div class="px-3 py-2 border-t border-white/5 flex items-center gap-2">
        <div class="size-7 rounded-full bg-indigo-600 flex items-center justify-center text-xs font-bold text-white flex-shrink-0">J</div>
        <div class="min-w-0">
          <div class="text-xs font-medium text-white truncate">jeff</div>
          <div class="text-xs text-green-400">Active</div>
        </div>
      </div>
    </div>

    <!-- Main area -->
    <div class="flex-1 flex flex-col min-w-0">

      <!-- Channel header -->
      <div class="flex items-center gap-2 px-4 py-3 border-b border-white/5 flex-shrink-0" style="background: #1a1d21;">
        <span class="text-zinc-400 font-medium">#</span>
        <span class="text-sm font-bold text-white">general</span>
        <div class="ml-auto flex items-center gap-3">
          <svg class="size-4 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <svg class="size-4 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
        </div>
      </div>

      <!-- Messages area -->
      <div class="flex-1 overflow-hidden px-4 pt-4 pb-2 flex flex-col justify-end gap-3 min-h-0">

        <!-- Previous message context (static) -->
        <div class="flex items-start gap-2.5 opacity-40">
          <div class="size-8 rounded-lg bg-teal-700 flex items-center justify-center text-xs font-bold text-white flex-shrink-0">S</div>
          <div>
            <div class="flex items-baseline gap-2">
              <span class="text-xs font-bold text-white">sara</span>
              <span class="text-xs" style="color:#616061;">10:42 AM</span>
            </div>
            <p class="text-sm mt-0.5" style="color:#d1d2d3;">anyone have a good reaction for this? 🎉</p>
          </div>
        </div>

        <!-- Animated conversation -->
        <div id="demo-conversation" class="flex flex-col gap-3">

          <!-- User command message (animated in) -->
          <div id="demo-user-msg" class="flex items-start gap-2.5 opacity-0 transition-opacity duration-300">
            <div class="size-8 rounded-lg bg-indigo-600 flex items-center justify-center text-xs font-bold text-white flex-shrink-0">J</div>
            <div>
              <div class="flex items-baseline gap-2">
                <span class="text-xs font-bold text-white">jeff</span>
                <span class="text-xs" style="color:#616061;">10:43 AM</span>
              </div>
              <p id="demo-command-text" class="text-sm mt-0.5 font-mono" style="color:#d1d2d3;"></p>
            </div>
          </div>

          <!-- Remoji typing indicator -->
          <div id="demo-typing" class="flex items-start gap-2.5 opacity-0 transition-opacity duration-300">
            <div class="size-8 rounded-lg bg-violet-700 flex items-center justify-center text-base flex-shrink-0">😄</div>
            <div>
              <div class="flex items-baseline gap-2">
                <span class="text-xs font-bold text-white">Remoji</span>
                <span class="text-xs rounded px-1 py-px" style="background:#2d2d2d; color:#a0a0a0; font-size:10px;">App</span>
              </div>
              <div class="mt-1.5 flex items-center gap-1 px-3 py-2 rounded-xl w-14" style="background:#222529;">
                <span class="typing-dot size-2 rounded-full bg-zinc-400"></span>
                <span class="typing-dot size-2 rounded-full bg-zinc-400" style="animation-delay:0.2s"></span>
                <span class="typing-dot size-2 rounded-full bg-zinc-400" style="animation-delay:0.4s"></span>
              </div>
            </div>
          </div>

          <!-- Remoji response -->
          <div id="demo-response" class="flex items-start gap-2.5 opacity-0 transition-opacity duration-300">
            <div class="size-8 rounded-lg bg-violet-700 flex items-center justify-center text-base flex-shrink-0 select-none">😄</div>
            <div class="min-w-0">
              <div class="flex items-baseline gap-2">
                <span class="text-xs font-bold text-white">Remoji</span>
                <span class="text-xs rounded px-1 py-px" style="background:#2d2d2d; color:#a0a0a0; font-size:10px;">App</span>
                <span class="text-xs" style="color:#616061;">10:43 AM</span>
              </div>
              <p class="text-sm mt-0.5" style="color:#d1d2d3;">
                Here are the closest matches to <span class="font-mono text-violet-300">:partyparrot:</span> in your workspace:
              </p>
              <div id="demo-emojis" class="mt-2 flex flex-wrap gap-1.5">
                <!-- Populated by JS -->
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- Message input -->
      <div class="px-4 pb-3 pt-1 flex-shrink-0">
        <div class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm border border-white/10" style="background:#222529;">
          <svg class="size-4 text-zinc-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 5v14m-7-7h14"/></svg>
          <span id="demo-input-text" class="flex-1 text-sm" style="color:#868686;"></span>
          <span id="demo-cursor" class="w-px h-4 bg-zinc-400 opacity-0"></span>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  .typing-dot {
    animation: typingBounce 1s ease-in-out infinite;
  }
  @keyframes typingBounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-4px); opacity: 1; }
  }
</style>

<script>
  const COMMAND = '/remoji :partyparrot:';

  const emojiSets = [
    [
      { name: 'party_blob',        file: 'party_blob.gif' },
      { name: 'meow_party',        file: 'meow_party.gif' },
      { name: 'bananadance',       file: 'bananadance.gif' },
      { name: 'extreme-teamwork',  file: 'extreme-teamwork.gif' },
      { name: 'blob-yes',          file: 'blob-yes.png' },
      { name: 'chefs-kiss',        file: 'chefs-kiss.gif' },
    ],
    [
      { name: 'meow_party',             file: 'meow_party.gif' },
      { name: 'bananadance',            file: 'bananadance.gif' },
      { name: 'party_blob',             file: 'party_blob.gif' },
      { name: 'typingcat',              file: 'typingcat.gif' },
      { name: 'blob_aww',               file: 'blob_aww.png' },
      { name: 'mild-panic-intensifies', file: 'mild-panic-intensifies.gif' },
    ],
    [
      { name: 'bananadance',       file: 'bananadance.gif' },
      { name: 'extreme-teamwork',  file: 'extreme-teamwork.gif' },
      { name: 'blob_smiley',       file: 'blob_smiley.png' },
      { name: 'meow_party',        file: 'meow_party.gif' },
      { name: 'blob-no',           file: 'blob-no.png' },
      { name: 'chefs-kiss',        file: 'chefs-kiss.gif' },
    ],
  ];

  const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');

  let setIndex = 0;

  function sleep(ms: number) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  function el(id: string) {
    return document.getElementById(id)!;
  }

  function show(id: string) { el(id).style.opacity = '1'; }
  function hide(id: string) { el(id).style.opacity = '0'; }

  async function typeCommand() {
    const inputText = el('demo-input-text');
    const cursor = el('demo-cursor');
    cursor.style.opacity = '1';

    // blink cursor briefly before typing
    await sleep(600);

    for (let i = 0; i <= COMMAND.length; i++) {
      inputText.textContent = COMMAND.slice(0, i);
      await sleep(i === 0 ? 0 : 55 + Math.random() * 40);
    }

    await sleep(350);
    cursor.style.opacity = '0';
  }

  function buildEmojiChips(emojis: typeof emojiSets[0]) {
    const container = el('demo-emojis');
    container.innerHTML = '';
    for (const e of emojis) {
      const chip = document.createElement('div');
      chip.className = 'inline-flex items-center gap-1.5 rounded-lg px-2 py-1.5 opacity-0 transition-all duration-200';
      chip.style.cssText = 'background:#2d2d2d; border: 1px solid rgba(255,255,255,0.06);';
      chip.innerHTML = `
        <img src="${BASE}/emojis/${e.file}" alt=":${e.name}:" class="size-5 object-contain" />
        <span class="text-xs font-mono" style="color:#a0a0a0;">:${e.name}:</span>
      `;
      container.appendChild(chip);
    }
  }

  async function showEmojiChips() {
    const chips = el('demo-emojis').children;
    for (let i = 0; i < chips.length; i++) {
      (chips[i] as HTMLElement).style.opacity = '1';
      await sleep(80);
    }
  }

  async function runDemo() {
    const emojis = emojiSets[setIndex % emojiSets.length];
    setIndex++;

    // Reset
    hide('demo-user-msg');
    hide('demo-typing');
    hide('demo-response');
    el('demo-command-text').textContent = '';
    el('demo-input-text').textContent = '';
    buildEmojiChips(emojis);

    await sleep(800);

    // Type into input box
    await typeCommand();

    // "Send" — move to message
    el('demo-input-text').textContent = '';
    el('demo-command-text').textContent = COMMAND;
    show('demo-user-msg');

    await sleep(400);

    // Remoji typing indicator
    show('demo-typing');
    await sleep(1400);
    hide('demo-typing');

    // Response appears
    show('demo-response');
    await sleep(100);
    await showEmojiChips();

    // Hold so user can read it
    await sleep(4000);

    // Fade whole conversation out gently
    const convo = el('demo-conversation');
    convo.style.transition = 'opacity 0.6s';
    convo.style.opacity = '0';
    await sleep(700);
    convo.style.transition = '';
    convo.style.opacity = '1';

    // Loop
    runDemo();
  }

  // Start after a short delay so page has painted
  setTimeout(runDemo, 500);
</script>
