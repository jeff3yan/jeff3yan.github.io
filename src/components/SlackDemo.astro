---
---

<div class="relative mx-auto mt-16 max-w-3xl px-6">
  <!-- glow -->
  <div
    class="pointer-events-none absolute -inset-6 rounded-3xl opacity-20"
    style="background: radial-gradient(ellipse at 50% 50%, rgb(139,92,246), transparent 70%);"
  ></div>

  <!-- Slack window -->
  <div
    class="relative rounded-2xl overflow-hidden shadow-2xl border border-white/10 flex select-none"
    style="height: 500px; background: #1a1d21;"
  >
    <!-- Sidebar (hidden on mobile) -->
    <div class="hidden md:flex flex-shrink-0 w-52 flex-col border-r border-white/5" style="background: #19171d;">
      <div class="px-4 py-3 flex items-center justify-between border-b border-white/5">
        <span class="text-sm font-bold text-white truncate">Meridian</span>
        <svg class="size-4 text-zinc-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 5v7m0 0v7m0-7h7m-7 0H5"/></svg>
      </div>
      <div class="flex-1 overflow-hidden py-2 px-2 space-y-0.5 text-sm">
        <div class="px-2 py-0.5 text-xs font-semibold uppercase tracking-wide mt-1" style="color:#7a7a7a;">Channels</div>
        {[
          { name: 'general',       active: true,  badge: null },
          { name: 'random',        active: false, badge: 3 },
          { name: 'design',        active: false, badge: null },
          { name: 'engineering',   active: false, badge: null },
          { name: 'announcements', active: false, badge: null },
        ].map(ch => (
          <div
            class={`px-2 py-1 rounded flex items-center gap-2 cursor-default text-sm ${ch.active ? 'font-medium' : ''}`}
            style={ch.active ? 'background: rgba(139,92,246,0.25); color: #fff;' : 'color: #9e9e9e;'}
          >
            <span style="color:#616061;">#</span>
            <span class="truncate">{ch.name}</span>
            {ch.badge && (
              <span class="ml-auto text-xs rounded-full px-1.5 py-0.5 leading-none font-bold" style="background:#cd2553; color:#fff;">{ch.badge}</span>
            )}
          </div>
        ))}
      </div>
      <div class="px-3 py-2 border-t border-white/5 flex items-center gap-2">
        <div class="size-7 rounded-full bg-indigo-600 flex items-center justify-center text-xs font-bold text-white flex-shrink-0">J</div>
        <div class="min-w-0">
          <div class="text-xs font-medium text-white truncate">jeff</div>
          <div class="text-xs" style="color:#2bac76;">Active</div>
        </div>
      </div>
    </div>

    <!-- Main panel -->
    <div class="flex-1 flex flex-col min-w-0">

      <!-- Channel header -->
      <div class="flex items-center gap-2 px-4 py-2.5 border-b flex-shrink-0" style="background:#1a1d21; border-color: rgba(255,255,255,0.07);">
        <span class="font-bold" style="color:#9e9e9e;">#</span>
        <span class="text-sm font-bold text-white">general</span>
        <div class="ml-auto flex items-center gap-3">
          <svg class="size-4" style="color:#9e9e9e;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <svg class="size-4" style="color:#9e9e9e;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
        </div>
      </div>

      <!-- Messages -->
      <div class="flex-1 overflow-hidden flex flex-col min-h-0 px-4 pt-5 pb-2" style="gap: 0;">

        <!-- Static context messages -->
        <div class="flex flex-col gap-4 opacity-50">

          <div class="flex items-start gap-3">
            <div class="size-9 rounded-lg flex items-center justify-center text-xs font-bold text-white flex-shrink-0" style="background:#2e7d6e;">A</div>
            <div>
              <div class="flex items-baseline gap-2">
                <span class="text-sm font-bold text-white">alex</span>
                <span class="text-xs" style="color:#616061;">10:41 AM</span>
              </div>
              <p class="text-sm mt-0.5" style="color:#d1d2d3;">heads up, all hands at 3 — think they're finally announcing the roadmap 👀</p>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <div class="size-9 rounded-lg flex items-center justify-center text-xs font-bold text-white flex-shrink-0" style="background:#6b3e9e;">M</div>
            <div>
              <div class="flex items-baseline gap-2">
                <span class="text-sm font-bold text-white">maya</span>
                <span class="text-xs" style="color:#616061;">10:42 AM</span>
              </div>
              <p class="text-sm mt-0.5" style="color:#d1d2d3;">ooh finally!! blocking my calendar now</p>
            </div>
          </div>

        </div>

        <!-- Animated section — pre-sized to prevent layout shift -->
        <div class="relative flex-shrink-0 mt-4" style="height: 130px;">

          <!-- Typing indicator (absolutely positioned, no layout impact) -->
          <div id="demo-typing" class="absolute inset-x-0 top-0 flex items-start gap-3" style="opacity:0; transition: opacity 0.2s;">
            <div class="size-9 rounded-lg flex items-center justify-center text-lg flex-shrink-0" style="background: #4a154b;">
              😄
            </div>
            <div>
              <div class="flex items-baseline gap-2">
                <span class="text-sm font-bold text-white">Remoji</span>
                <span class="text-xs rounded px-1.5 py-px font-medium" style="background:#1d1d1d; color:#9e9e9e; font-size:10px; border: 1px solid rgba(255,255,255,0.08);">App</span>
              </div>
              <div class="mt-2 flex items-center gap-1 px-3 py-2 rounded-lg w-16" style="background:#222529;">
                <span class="typing-dot size-2 rounded-full" style="background:#9e9e9e;"></span>
                <span class="typing-dot size-2 rounded-full" style="background:#9e9e9e; animation-delay:0.18s;"></span>
                <span class="typing-dot size-2 rounded-full" style="background:#9e9e9e; animation-delay:0.36s;"></span>
              </div>
            </div>
          </div>

          <!-- Ephemeral response (absolutely positioned, no layout impact) -->
          <div id="demo-response" class="absolute inset-x-0 top-0 flex items-start gap-3 rounded-lg px-3 py-2" style="opacity:0; transition: opacity 0.25s; background: rgba(227,196,67,0.07); border-left: 3px solid rgba(227,196,67,0.35);">
            <div class="size-9 rounded-lg flex items-center justify-center text-lg flex-shrink-0 flex-shrink-0" style="background: #4a154b;">
              😄
            </div>
            <div class="min-w-0">
              <div class="flex items-baseline gap-2">
                <span class="text-sm font-bold text-white">Remoji</span>
                <span class="text-xs rounded px-1.5 py-px font-medium" style="background:#1d1d1d; color:#9e9e9e; font-size:10px; border: 1px solid rgba(255,255,255,0.08);">App</span>
                <span class="text-xs" style="color:#616061;">10:43 AM</span>
              </div>
              <!-- Actual response format: source → results, all as images -->
              <div id="demo-emoji-row" class="mt-1.5 flex items-center flex-wrap gap-1"></div>
              <!-- Ephemeral indicator -->
              <div class="mt-1.5 flex items-center gap-1" style="color:#616061;">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                <span class="text-xs italic">Only visible to you</span>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- Input box -->
      <div class="px-4 pb-4 pt-1 flex-shrink-0">
        <div class="flex items-center gap-2 rounded-lg px-3 py-2.5 border" style="background:#222529; border-color:rgba(255,255,255,0.1);">
          <svg class="size-4 flex-shrink-0" style="color:#616061;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 5v14m-7-7h14"/></svg>
          <span class="flex-1 flex items-center">
            <span id="demo-input-text" class="text-sm whitespace-nowrap" style="color:#d1d2d3;"></span><span id="demo-cursor" class="inline-block w-0.5 h-4 rounded-full flex-shrink-0" style="background:#d1d2d3; opacity:0; vertical-align:text-bottom;"></span>
          </span>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  .typing-dot {
    animation: typingBounce 1.1s ease-in-out infinite;
  }
  @keyframes typingBounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.35; }
    30% { transform: translateY(-3px); opacity: 1; }
  }
  #demo-cursor {
    animation: none;
  }
  #demo-cursor.blinking {
    animation: cursorBlink 0.9s step-end infinite;
  }
  @keyframes cursorBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>

<script>
  const COMMAND = '/remoji :partyparrot:';

  type Emoji = { name: string; file: string };

  const emojiSets: Emoji[][] = [
    [
      { name: 'party_blob',        file: 'party_blob.gif' },
      { name: 'meow_party',        file: 'meow_party.gif' },
      { name: 'bananadance',       file: 'bananadance.gif' },
      { name: 'extreme-teamwork',  file: 'extreme-teamwork.gif' },
      { name: 'blob-yes',          file: 'blob-yes.png' },
      { name: 'chefs-kiss',        file: 'chefs-kiss.gif' },
    ],
    [
      { name: 'meow_party',             file: 'meow_party.gif' },
      { name: 'bananadance',            file: 'bananadance.gif' },
      { name: 'party_blob',             file: 'party_blob.gif' },
      { name: 'typingcat',              file: 'typingcat.gif' },
      { name: 'blob_aww',               file: 'blob_aww.png' },
      { name: 'mild-panic-intensifies', file: 'mild-panic-intensifies.gif' },
    ],
    [
      { name: 'bananadance',       file: 'bananadance.gif' },
      { name: 'extreme-teamwork',  file: 'extreme-teamwork.gif' },
      { name: 'blob_smiley',       file: 'blob_smiley.png' },
      { name: 'meow_party',        file: 'meow_party.gif' },
      { name: 'blob-no',           file: 'blob-no.png' },
      { name: 'chefs-kiss',        file: 'chefs-kiss.gif' },
    ],
  ];

  const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');

  let setIndex = 0;

  const sleep = (ms: number) => new Promise<void>(r => setTimeout(r, ms));
  const el = (id: string) => document.getElementById(id) as HTMLElement;

  function buildEmojiRow(emojis: Emoji[]) {
    const row = el('demo-emoji-row');
    row.innerHTML = '';

    // Source emoji
    const src = document.createElement('img');
    src.src = `${BASE}/emojis/party_parrot_animated.gif`;
    src.alt = ':partyparrot:';
    src.title = ':partyparrot:';
    src.className = 'object-contain';
    src.style.cssText = 'width:22px; height:22px; opacity:0; transition: opacity 0.15s;';
    row.appendChild(src);

    // Arrow
    const arrow = document.createElement('span');
    arrow.textContent = '→';
    arrow.style.cssText = 'color:#9e9e9e; font-size:13px; margin: 0 2px; flex-shrink:0;';
    row.appendChild(arrow);

    // Result emojis
    for (const e of emojis) {
      const img = document.createElement('img');
      img.src = `${BASE}/emojis/${e.file}`;
      img.alt = `:${e.name}:`;
      img.title = `:${e.name}:`;
      img.className = 'object-contain';
      img.style.cssText = 'width:22px; height:22px; opacity:0; transition: opacity 0.15s;';
      row.appendChild(img);
    }
  }

  async function revealEmojiRow() {
    const imgs = el('demo-emoji-row').querySelectorAll('img');
    for (let i = 0; i < imgs.length; i++) {
      (imgs[i] as HTMLElement).style.opacity = '1';
      await sleep(70);
    }
  }

  async function runDemo() {
    const emojis = emojiSets[setIndex % emojiSets.length];
    setIndex++;

    // Reset state
    el('demo-typing').style.opacity = '0';
    el('demo-response').style.opacity = '0';
    el('demo-input-text').textContent = '';
    buildEmojiRow(emojis);

    await sleep(900);

    // Show blinking cursor
    const cursor = el('demo-cursor');
    cursor.style.opacity = '1';
    cursor.classList.add('blinking');

    await sleep(500);

    // Type the command
    const inputEl = el('demo-input-text');
    for (let i = 0; i <= COMMAND.length; i++) {
      inputEl.textContent = COMMAND.slice(0, i);
      await sleep(55 + Math.random() * 35);
    }

    // Pause before "send"
    await sleep(400);

    // Send: clear input (commands disappear in Slack)
    cursor.classList.remove('blinking');
    cursor.style.opacity = '0';
    inputEl.textContent = '';

    await sleep(200);

    // Remoji typing indicator
    el('demo-typing').style.opacity = '1';
    await sleep(1300);
    el('demo-typing').style.opacity = '0';
    await sleep(80);

    // Ephemeral response appears
    el('demo-response').style.opacity = '1';
    await sleep(120);
    await revealEmojiRow();

    // Hold to read
    await sleep(9000);

    // Fade out response
    el('demo-response').style.transition = 'opacity 0.5s';
    el('demo-response').style.opacity = '0';
    await sleep(600);
    el('demo-response').style.transition = 'opacity 0.25s';

    runDemo();
  }

  setTimeout(runDemo, 600);
</script>
