---
const items = [
  { icon: '🔒', label: 'No message access', detail: 'Reads emoji list only' },
  { icon: '🎯', label: 'Scoped permissions', detail: 'Minimal Slack access' },
  { icon: '🏢', label: 'Workspace isolation', detail: 'Your data stays yours' },
  { icon: '✅', label: 'Audit-ready', detail: 'Enterprise-grade infra' },
];
---

<section id="security" class="py-16 px-6 border-t border-white/10">
  <div class="mx-auto max-w-6xl">
    <div class="fade-up text-center mb-8">
      <p class="text-sm font-medium text-slate-400 uppercase tracking-wide">Built to pass security reviews</p>
    </div>
    <div class="fade-up grid grid-cols-2 sm:grid-cols-4 gap-4">
      {items.map(item => (
        <div class="flex flex-col items-center gap-2 rounded-xl border border-white/8 bg-white/[0.02] px-4 py-5 text-center">
          <span class="text-2xl">{item.icon}</span>
          <span class="text-sm font-semibold text-white">{item.label}</span>
          <span class="text-xs text-slate-500">{item.detail}</span>
        </div>
      ))}
    </div>
  </div>
</section>
